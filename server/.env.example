# ─── 数据库（推荐 PostgreSQL/Supabase）───────────────
# Supabase 连接串（从 Project Settings → Database 获取）
DATABASE_URL=postgresql://postgres.你的项目ID:你的密码@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres
# SQLite（本地开发快速启动）
# DATABASE_URL=sqlite:///./app.db

# ─── 安全 ────────────────────────────────────────────
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ─── AI ──────────────────────────────────────────────
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-v4-pro

# ─── Embedding 检索模型 ─────────────────────────────
# 不配置时使用本地轻量哈希向量；要用真实 embedding 模型，改成 openai_compatible。
EMBEDDING_PROVIDER=hash
# EMBEDDING_PROVIDER=openai_compatible
# EMBEDDING_API_KEY=sk-your-embedding-api-key
# EMBEDDING_BASE_URL=https://api.openai.com/v1
# EMBEDDING_MODEL=text-embedding-3-small

# ─── 存储 ────────────────────────────────────────────
UPLOAD_DIR=uploads
